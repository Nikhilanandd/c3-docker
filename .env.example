# ===========================================
# Docker Deployment Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# --- MongoDB ---
# Default connects to the local MongoDB container.
# Override with an external MongoDB Atlas URI if needed.
MONGO_URI=mongodb://mongodb:27017/c3database

# --- Backend ---
# API security key (generate a random 32-char string)
API_KEY=generate_a_random_32_character_string_here

# CORS - allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# --- Email / Google OAuth2 (for Gmail API) ---
EMAIL_USER=your_email@gmail.com
CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token

# --- Frontend ---
# URL the frontend uses to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:5000
